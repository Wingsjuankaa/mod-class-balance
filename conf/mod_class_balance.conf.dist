################################################################################
# mod-class-balance – Ajuste de multiplicadores de combate por clase
################################################################################
# Versión: 1.1.0
#
# Permite ajustar el daño dado, el daño recibido y la curación de cada clase
# de jugador de forma independiente, en caliente, mediante comandos de GM
# o editando directamente las tablas de acore_world.
#
# ── BALANCE POR CLASE ─────────────────────────────────────────────────────────
# Los valores se almacenan en mod_class_balance.
# Comandos (requieren nivel GM):
#   .classbalance list               – Muestra todos los multiplicadores
#   .classbalance info <clase>       – Detalle de una clase
#   .classbalance set <clase> <tipo> <valor>
#                                    – Ajusta un multiplicador (live + BD)
#                                      tipos: phys | spell | heal | def
#   .classbalance reset <clase>      – Resetea clase a 1.0
#   .classbalance reload             – Recarga todos los valores desde la BD
#
# Ejemplos:
#   .classbalance set warrior phys 1.15    → +15% daño físico a Guerreros
#   .classbalance set mage spell 0.90      → -10% daño hechizo a Magos
#   .classbalance set paladin heal 1.10    → +10% curación de Paladines
#   .classbalance set priest def 0.85      → Sacerdotes reciben 15% menos daño
#
# ── BALANCE POR HECHIZO ESPECÍFICO ────────────────────────────────────────────
# Los overrides se almacenan en mod_class_balance_spells.
# Los multiplicadores por hechizo se APILAN con los de clase:
#   daño final = clase.spell_dmg × hechizo.dmg_mult
#
# Comandos:
#   .classbalance spell list                      – Lista hechizos con override
#   .classbalance spell info <spell_id>           – Detalle de un hechizo
#   .classbalance spell set <spell_id> <tipo> <valor>
#                                                 – tipos: dmg | heal
#   .classbalance spell reset <spell_id>          – Elimina el override
#
# Ejemplos:
#   .classbalance spell set 133 dmg 0.85     → Bola de fuego -15% daño
#   .classbalance spell set 48778 dmg 0.90   → Toque de agonía -10%
#   .classbalance spell set 48785 heal 1.20  → Destello de luz +20% curación
#   .classbalance spell reset 133            → Elimina override de Bola de fuego
#
# Clases válidas (inglés o español):
#   warrior/guerrero, paladin, hunter/cazador, rogue/picaro,
#   priest/sacerdote, deathknight/dk, shaman/chaman,
#   mage/mago, warlock/brujo, druid/druida
################################################################################

[worldserver]

#
# ClassBalance.Enable
#   Activa o desactiva el módulo.
#   Predeterminado: 1 (activado)
#
ClassBalance.Enable = 1

#
# ClassBalance.ApplyInPvP
#   Aplica los multiplicadores también en combate JcJ (jugador vs jugador).
#   Si se desactiva, los modificadores solo afectan a daño contra NPCs/criaturas.
#   Predeterminado: 1 (activado)
#
ClassBalance.ApplyInPvP = 1

#
# ClassBalance.ApplyInPvE
#   Aplica los multiplicadores en combate JcE (jugador vs entorno/NPCs).
#   Predeterminado: 1 (activado)
#
ClassBalance.ApplyInPvE = 1

